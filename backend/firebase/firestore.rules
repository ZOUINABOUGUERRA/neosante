rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSageFemme() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sage-femme';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Dossiers Prématurés
    match /dossiers_prematures/{dossierId} {
      allow read: if isAuthenticated();
      allow create: if isSageFemme() || isAdmin();
      allow update: if isSageFemme() || isAdmin();
      allow delete: if isAdmin();
    }

    // Dossiers À Terme
    match /dossiers_a_terme/{dossierId} {
      allow read: if isAuthenticated();
      allow create: if isSageFemme() || isAdmin();
      allow update: if isSageFemme() || isAdmin();
      allow delete: if isAdmin();
    }

    // Alerts
    match /alerts/{alertId} {
      allow read, write: if isAuthenticated();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated();
    }

    // Transfers
    match /transfers/{transferId} {
      allow read: if isAuthenticated();
      allow create, update: if isSageFemme() || isAdmin();
    }

    // Surveillance
    match /surveillance/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Archives
    match /archives/{archiveId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Backups metadata
    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }
  }
  
  // Ajouter/modifier ces règles dans backend/firebase/firestore.rules

// Pour la collection users, permettre à l'admin de tout faire
match /users/{userId} {
  allow read: if isAuthenticated();
  allow create: if isAdmin() || request.auth.uid == userId;
  allow update: if isAdmin() || request.auth.uid == userId;
  allow delete: if isAdmin();
}

// Pour la collection archives, permettre à l'admin de tout lire
match /archives/{archiveId} {
  allow read: if isAuthenticated() && (isAdmin() || resource.data.createdBy == request.auth.uid);
  allow write: if isAdmin();
}
}