rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSageFemme() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sage-femme';
    }

    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || request.auth.uid == userId;
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ==================== DOSSIERS PRÉMATURÉS ====================
    match /dossiers_prematures/{dossierId} {
      allow read: if isAuthenticated();
      allow create: if isSageFemme() || isAdmin();
      allow update: if isSageFemme() || isAdmin();
      allow delete: if isAdmin();
    }

    // ==================== DOSSIERS À TERME ====================
    match /dossiers_a_terme/{dossierId} {
      allow read: if isAuthenticated();
      allow create: if isSageFemme() || isAdmin();
      allow update: if isSageFemme() || isAdmin();
      allow delete: if isAdmin();
    }

    // ==================== ALERTS ====================
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow write: if isSageFemme() || isAdmin();
    }

    // ==================== NOTIFICATIONS ====================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ==================== TRANSFERS ====================
    match /transfers/{transferId} {
      allow read: if isAuthenticated();
      allow create: if isSageFemme() || isAdmin();
      allow update: if isSageFemme() || isAdmin();
    }

    // ==================== SURVEILLANCE ====================
    match /surveillance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSageFemme() || isAdmin();
    }

    // ==================== ARCHIVES ====================
    match /archives/{archiveId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow write: if isAdmin();
    }

    // ==================== BACKUPS ====================
    match /backups/{backupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}